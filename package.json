{
  "name": "@arkangelai/second-brain",
  "version": "0.1.0",
  "description": "Local-first, AI-native knowledge management. Monorepo: Next.js web app + Bun CLI + shared contracts.",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --filter='./apps/*' --filter='./packages/cli' --parallel dev",
    "dev:web": "bun run --filter='./apps/web' dev",
    "dev:cli": "bun run --filter='./packages/cli' dev",
    "build": "bun run --filter='./apps/*' build",
    "test": "bun run --filter='./packages/*' test",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "eslint ."
  },
  "keywords": [
    "second-brain",
    "knowledge-management",
    "cli",
    "obsidian",
    "qmd",
    "ai",
    "markdown"
  ],
  "author": "Arkangel AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arkangelai/second-brain.git"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.16.0"
  }
}
