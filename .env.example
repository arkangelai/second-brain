# ─────────────────────────────────────────────────────────────────────────────
# Second Brain — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local (web app) or export in your shell (CLI), then fill in.
# Anything blank or missing here causes `bun run check:env` to exit non-zero.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined into the browser bundle.
# Never put server-only secrets (service role keys, API tokens) behind that
# prefix — the Zod schema in packages/shared/src/env.ts will refuse to boot
# the web app if a service-role JWT ends up in a public var.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Supabase ───────────────────────────────────────────────────────────────
# Project settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Server-only. Bypasses RLS. Never expose to the browser.
# Use Secret API keys (sb_secret_...). Legacy service_role JWTs still work but
# are being phased out by Supabase — prefer Secret keys (rotatable, scoped).
SUPABASE_SECRET_KEY=

# Server-only. Direct Postgres connection used for transaction-scoped RLS GUCs.
# Use a dedicated login role that is a member of `authenticated` and does not
# own tables or have BYPASSRLS. Do not use the Supabase `postgres` owner role.
SUPABASE_DATABASE_URL=postgresql://second_brain_app:password@127.0.0.1:54322/postgres

# Public-safe. Used by the browser client (RLS enforced).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ─── Vercel AI Gateway ──────────────────────────────────────────────────────
# Vercel dashboard → AI Gateway → API keys
# https://vercel.com/docs/ai-gateway

AI_GATEWAY_API_KEY=


# ─── Resend (transactional email) ───────────────────────────────────────────
# https://resend.com/api-keys

RESEND_API_KEY=
EMAIL_FROM=noreply@example.com


# ─── App ────────────────────────────────────────────────────────────────────
# Canonical URL of this deployment. Used for absolute links in emails, OAuth
# redirects, and OG images. No trailing slash.

APP_URL=http://localhost:3000

# Display name used in the UI, emails, and the browser tab title.
NEXT_PUBLIC_APP_NAME=Second Brain


# ─── CLI (packages/cli) ─────────────────────────────────────────────────────
# The CLI is local-first today. App-issued API tokens for remote access will
# be generated by the web app and backed by Supabase in the auth/schema work.

# Optional: override the local vault path (default: ~/Documents/Second_Brain).
# SECOND_BRAIN_PATH=
